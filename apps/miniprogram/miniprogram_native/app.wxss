page {
  --color-primary: #1aad19;
  --color-danger: #e74c3c;
  --color-warning: #f39c12;
  --color-bg: #f5f5f5;
  --color-text: #333333;
  --color-text-secondary: #999999;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 14px;
  color: var(--color-text);
  background-color: var(--color-bg);
}

.container {
  padding: 24rpx;
}
